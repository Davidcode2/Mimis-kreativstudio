---
// Services data with content from CONTENT.md
const services = [
  {
    slug: 'blumenkraenze',
    title: 'Blumenkränze',
    subtitle: 'Zeitlose Eleganz',
    description: 'Handgefertigte Blumenkränze aus natürlichen Blumen, mit Liebe zum Detail gestaltet.',
    image: '/images/services/blumenkraenze/kranz_standard.webp',
    imagePosition: 'top-right' as const,
    cornerIndex: 0,
  },
  {
    slug: 'loops',
    title: 'Loops',
    subtitle: 'Moderne Eleganz',
    description: 'Der zeitgemäße Schwester des traditionellen Kranzes – minimalistisch und stilvoll.',
    image: '/images/services/loops/loop_standard_rot_gruen.webp',
    imagePosition: 'top-right' as const,
    cornerIndex: 1,
  },
  {
    slug: 'bluemenstrausse',
    title: 'Blumensträuße',
    subtitle: 'Natürliche Schönheit',
    description: 'Frische Blumen, mit Liebe zusammengestellt – ein persönliches Statement.',
    image: '/images/services/bluemenstrausse/brautsrauss_lila.webp',
    imagePosition: 'bottom-left' as const,
    cornerIndex: 2,
  },
  {
    slug: 'adventskraenze',
    title: 'Adventskränze',
    subtitle: 'Festliche Tradition',
    description: 'Traditionelles Handwerk für die schönste Zeit des Jahres mit weihnachtlicher Gemütlichkeit.',
    image: '/images/services/adventskraenze/kranz_hortensie_mit_kerze.webp',
    imagePosition: 'top-right' as const,
    cornerIndex: 3,
  },
  {
    slug: 'frisuren',
    title: 'Frisuren',
    subtitle: 'Romantischer Schmuck',
    description: 'Zarte Blüten für Ihr Haar – romantischer Schmuck für unvergessliche Momente.',
    image: '/images/services/frisuren/haarkranz_ganz.webp',
    imagePosition: 'top-right' as const,
    cornerIndex: 4,
  },
  {
    slug: 'workshops',
    title: 'Workshops',
    subtitle: 'Kreatives Erlebnis',
    description: 'Lernen Sie die Kunst der Floristik – für sich selbst oder im Team.',
    image: '/images/services/workshops/loop_workshop_done_small.webp',
    imagePosition: 'bottom-right' as const,
    cornerIndex: 5,
  },
];

// Alternate corner positions for visual variety
const cornerPositions = ['top-right', 'bottom-left', 'top-right', 'top-right', 'top-right', 'bottom-right'] as const;
---

<section id="leistungen" class="py-12 sm:py-16 md:py-20 bg-gold-50">
  <div class="container mx-auto px-4">
    {/* Section Header */}
    <div class="text-center mb-10 sm:mb-12 md:mb-16">
      <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-gold-700 mb-3 sm:mb-4">
        Meine Leistungen
      </h2>
      <p class="font-body text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto px-4">
        Entdecken Sie meine handgefertigten Blumenkreationen für jeden besonderen Anlass
      </p>
      <div class="w-20 sm:w-24 h-1 bg-champagne-400 mx-auto mt-4 sm:mt-6 "></div>
    </div>

    {/* Services Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {services.map((service, index) => (
        <a 
          href={`/leistungen/${service.slug}`}
          class="block group"
        >
          <div class="relative overflow-hidden   transition-all duration-500 group-hover:shadow-2xl">
            {/* Image */}
            <div class="relative h-64 sm:h-72 md:h-80 bg-gray-200">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            </div>

            {/* Content overlay */}
            <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-white via-white to-transparent">
              <h3 class="font-heading text-2xl text-gold-700 mb-1 group-hover:text-gold-600 transition-colors">
                {service.title}
              </h3>
              <p class="text-champagne-600 font-medium text-sm mb-2">{service.subtitle}</p>
              <p class="text-gray-600 text-sm line-clamp-2">{service.description}</p>
              
              <span class="inline-flex items-center mt-3 text-gold-600 text-sm font-medium opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
                Mehr erfahren 
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>

            {/* Decorative corner accent */}
            <div class={`absolute w-16 h-16 border-t-2 border-r-2 border-gold-400 rounded-tr-xl
              ${index % 2 === 0 ? 'top-4 right-4' : 'top-4 left-4'}
            `}></div>
          </div>
        </a>
      ))}
    </div>

    {/* View All Link */}
    <div class="text-center mt-12">
      <a
        href="/leistungen"
        class="inline-flex items-center px-8 py-3 border-2 border-gold-500 text-gold-700 
          hover:bg-gold-500 hover:text-white transition-all duration-300 font-body"
      >
        Alle Leistungen ansehen
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>