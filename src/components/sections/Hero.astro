---
interface Props {
  title?: string;
  subtitle?: string;
  backgroundImage?: string;
  showCta?: boolean;
}

const {
  title = 'Mimis-kreativstudio',
  subtitle = 'Handgefertigte Blumenkreationen für Ihre besonderen Momente',
  backgroundImage = '/images/hero/hero-default.jpg',
  showCta = true
} = Astro.props;
---

<section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
  {/* Background Image */}
  <div class="absolute inset-0 z-0">
    <img
      src={backgroundImage}
      alt="Hero background"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-white/30 via-white/50 to-white/80"></div>
  </div>

  {/* Content */}
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-gold-700 mb-4 tracking-wide">
      {title}
    </h1>
    <p class="font-body text-xl md:text-2xl text-gray-700 mb-8 font-light italic">
      {subtitle}
    </p>
    
    {showCta && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/leistungen"
          class="inline-block px-8 py-3 border-2 border-gold-500 text-gold-700 rounded-lg
            hover:bg-gold-500 hover:text-white transition-all duration-300 font-body"
        >
          Meine Leistungen
        </a>
        <a
          href="/kontakt"
          class="inline-block px-8 py-3 bg-rose-400 text-white rounded-lg
            hover:bg-rose-500 transition-all duration-300 font-body"
        >
          Kontakt aufnehmen
        </a>
      </div>
    )}
  </div>

  {/* Decorative flourish */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-8 h-8 text-gold-500" fill="currentColor" viewBox="0 0 24 24">
      <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
    </svg>
  </div>
</section>