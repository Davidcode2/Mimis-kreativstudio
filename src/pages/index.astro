---
// Trigger build - 2026-03-15 - v4 (with src/ fix)
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ServicesList from '../components/sections/ServicesList.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import CTASection from '../components/sections/CTASection.astro';

const title = 'Startseite';
const description = 'Mimis-kreativstudio - Handgefertigte Blumenkreationen für Ihre besonderen Momente. Blumenkränze, Sträuße, Adventskränze, Haar-Accessoires und Workshops.';
---

<BaseLayout title={title} description={description}>
  <main>
    <!-- Hero Section -->
    <Hero
      title="Mimis-kreativstudio"
      subtitle="Handgefertigte Blumenkreationen für Ihre besonderen Momente"
      backgroundImage="/images/pride_back_hair_landscape_background.webp"
      showCta={true}
    />

    <!-- Introduction -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 text-center max-w-3xl">
        <p class="font-body text-xl text-gray-700 leading-relaxed italic">
          "Jede Blume erzählt eine Geschichte. Lassen Sie uns gemeinsam Ihre Geschichte 
          in wunderschönen Arrangements verewigen."
        </p>
        <div class="w-16 h-px bg-gold-400 mx-auto mt-6"></div>
      </div>
    </section>

    <!-- Services List -->
    <ServicesList />

    <!-- About Section -->
    <AboutSection />

    <!-- CTA Section -->
    <CTASection />
  </main>
</BaseLayout>
