---
---

<section class="py-12 sm:py-16 md:py-20 bg-gradient-to-br from-champagne-50 to-champagne-100">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-gold-700 mb-4 sm:mb-6">
        Bereit für Ihre Traumkreation?
      </h2>
      <p class="font-body text-lg sm:text-xl text-gray-700 mb-6 sm:mb-8 max-w-2xl mx-auto">
        Lassen Sie uns gemeinsam etwas Besonderes gestalten. Kontaktieren Sie mich für 
        ein unverbindliches Gespräch über Ihre Wünsche.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center px-4">
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 bg-gold-500 text-white 
            hover:bg-gold-600 transition-all duration-300 font-body text-base sm:text-lg  hover:shadow-xl"
        >
          Kontakt aufnehmen
          <svg class="w-4 h-4 sm:w-5 sm:h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
        <a
          href="/leistungen"
          class="inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 border-2 border-gold-500 text-gold-700 
            hover:bg-gold-500 hover:text-white transition-all duration-300 font-body text-base sm:text-lg"
        >
          Leistungen entdecken
        </a>
      </div>

      {/* Contact info cards */}
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mt-10 sm:mt-12 px-2 sm:px-0">
        <div class="bg-white p-5 sm:p-6  ">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-gold-100  flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-heading text-base sm:text-lg text-gold-700 mb-2">E-Mail</h3>
          <p class="text-gray-600 text-sm">hello@mimis-kreativstudio.de</p>
        </div>
        
        <div class="bg-white p-5 sm:p-6  ">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-champagne-100 flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-champagne-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="font-heading text-base sm:text-lg text-gold-700 mb-2">Telefon</h3>
          <p class="text-gray-600 text-sm">+49 (0) 123 456 789</p>
        </div>
        
        <div class="bg-white p-5 sm:p-6  ">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-gold-100  flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-heading text-base sm:text-lg text-gold-700 mb-2">Standort</h3>
          <p class="text-gray-600 text-sm">Region Stuttgart</p>
        </div>
      </div>
    </div>
  </div>
</section>