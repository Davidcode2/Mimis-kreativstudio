---
import PageLayout from '../../layouts/PageLayout.astro';
import { services } from '../../data/services';

const pageTitle = 'Unsere Leistungen';
const pageDescription = 'Entdecken Sie unsere handgefertigten Blumenkreationen – von traditionellen Kränzen über moderne Loops bis hin zu individuellen Sträuchen und Workshops.';
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  heroTitle="Unsere Leistungen"
  heroSubtitle="Handgefertigte Blumenkreationen mit Liebe zum Detail"
>
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-6xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <a
            href={`/leistungen/${service.slug}`}
            class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100"
          >
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={service.heroImage}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-6">
              <h2 class="font-heading text-2xl text-gray-900 mb-2 group-hover:text-gold-600 transition-colors">
                {service.title}
              </h2>
              <p class="text-gray-600 mb-4 line-clamp-2">{service.shortDescription}</p>
              <span class="inline-flex items-center text-gold-600 font-medium group-hover:underline">
                Mehr erfahren →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gold-50">
    <div class="container mx-auto max-w-4xl text-center px-4">
      <h2 class="font-heading text-4xl text-gray-900 mb-6">Noch Fragen?</h2>
      <p class="text-xl text-gray-700 mb-8">
        Wir helfen Ihnen gerne bei der Auswahl des perfekten Blumenschmucks für Ihren Anlass.
      </p>
      <a
        href="/kontakt"
        class="inline-block bg-gold-500 text-white px-8 py-4 rounded-full font-medium hover:bg-gold-600 transition-colors"
      >
        Kontakt aufnehmen
      </a>
    </div>
  </section>
</PageLayout>