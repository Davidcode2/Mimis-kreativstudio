---
// Kontakt page for Mimis-kreativstudio
// Created: 2026-03-15
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageCard from '../components/ui/ImageCard.astro';
import { siteConfig } from '../data/site-config';

const title = 'Kontakt';
const description = 'Kontaktieren Sie Mimis-kreativstudio für individuelle Blumenkreationen, Workshops und Anfragen.';
---

<BaseLayout title={title} description={description}>
  <main>
    {/* Hero Section */}
    <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img
          src="/images/pink_strauss_on_brown_table_outdoors.webp"
          alt="Kontakt Hintergrund"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-radial from-white/90 via-white/60 to-white/90"></div>
      </div>
      
      <div class="relative z-10 text-center px-4 max-w-3xl mx-auto">
        <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl text-gold-700 mb-4 tracking-wide">
          Kontakt
        </h1>
        <p class="font-body text-xl md:text-2xl text-gray-700 font-light italic">
          Lassen Sie uns gemeinsam etwas Schönes erschaffen
        </p>
      </div>
    </section>

    {/* Contact Section */}
    <section class="py-16 bg-gold-50">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
          
          {/* Contact Form */}
          <div class="bg-white p-8 border border-champagne-300">
            <h2 class="font-heading text-3xl text-gold-700 mb-6 text-center">
              Schreiben Sie mir
            </h2>
            
            <form 
              name="contact" 
              method="POST" 
              data-netlify="true" 
              data-netlify-honeypot="bot-field"
              class="space-y-6"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
              </p>
              
              {/* Name Field */}
              <div>
                <label for="name" class="block font-body text-sm text-gold-700 mb-2">
                  Name *
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Ihr vollständiger Name"
                  class="w-full px-4 py-3 border border-gold-300  focus:ring-2 focus:ring-gold-500 focus:border-gold-500 font-body text-gray-700 placeholder-gold-300/70"
                />
              </div>
              
              {/* Email Field */}
              <div>
                <label for="email" class="block font-body text-sm text-gold-700 mb-2">
                  E-Mail *
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="ihre@email.de"
                  class="w-full px-4 py-3 border border-gold-300  focus:ring-2 focus:ring-gold-500 focus:border-gold-500 font-body text-gray-700 placeholder-gold-300/70"
                />
              </div>
              
              {/* Phone Field */}
              <div>
                <label for="phone" class="block font-body text-sm text-gold-700 mb-2">
                  Telefon
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="Ihre Telefonnummer"
                  class="w-full px-4 py-3 border border-gold-300  focus:ring-2 focus:ring-gold-500 focus:border-gold-500 font-body text-gray-700 placeholder-gold-300/70"
                />
              </div>
              
              {/* Message Field */}
              <div>
                <label for="message" class="block font-body text-sm text-gold-700 mb-2">
                  Nachricht *
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Erzählen Sie mir von Ihrer Vision..."
                  class="w-full px-4 py-3 border border-gold-300  focus:ring-2 focus:ring-gold-500 focus:border-gold-500 font-body text-gray-700 placeholder-gold-300/70 resize-none"
                ></textarea>
              </div>
              
              {/* Submit Button */}
              <button
                type="submit"
                class="w-full py-4 bg-champagne-400 text-gold-800 border border-champagne-500 font-body text-lg hover:bg-champagne-500 transition-all duration-300"
              >
                Nachricht senden
              </button>
            </form>
          </div>
          
          {/* Business Information */}
          <div class="space-y-8">
            
            <div class="bg-white p-6 border border-gold-200/30">
              <h3 class="font-heading text-2xl text-gold-700 mb-4">
                Mimis-Kreativstudio
              </h3>
              <p class="text-gold-800">Individuelle Blumenkreationen für Ihre besonderen Momente. Ich freue mich darauf, Ihre Visionen zu verwirklichen.</p>
            </div>
            
            {/* Contact Details */}
            <div class="bg-white   p-6 border border-gold-200/30">
              <h3 class="font-heading text-2xl text-gold-700 mb-4">
                Kontaktdaten
              </h3>
              
              <div class="space-y-4 font-body text-gray-700">
                {/* Address */}
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-champagne-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <div>
                    <p class="font-medium text-gold-700">Atelier</p>
                    <p class="text-gray-600">Coming soon</p>
                  </div>
                </div>
                
                {/* Email */}
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-champagne-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  <div>
                    <p class="font-medium text-gold-700">E-Mail</p>
                    <p class="text-gray-600">{siteConfig.email}</p>
                  </div>
                </div>
              </div>
            </div>
            
            {/* Business Hours */}
            <div class="bg-white   p-6 border border-gold-200/30">
              <h3 class="font-heading text-2xl text-gold-700 mb-4">
                Öffnungszeiten
              </h3>
              
              <div class="space-y-2 font-body text-gray-700">
                <div class="flex justify-between py-2 border-b border-gold-100">
                  <span class="text-gold-600">Montag - Freitag</span>
                  <span class="text-gray-600">Coming soon</span>
                </div>
                <div class="flex justify-between py-2 border-b border-gold-100">
                  <span class="text-gold-600">Samstag</span>
                  <span class="text-gray-600">Coming soon</span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-gold-600">Sonntag</span>
                  <span class="text-gray-600">Geschlossen</span>
                </div>
              </div>
              
              <p class="text-sm text-gray-500 mt-4 italic font-body">
                * Gerne fertige ich auf Wunsch Ihre Traumkreation. Kontaktieren Sie mich!
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Map Section */}
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-8">
            <h2 class="font-heading text-4xl text-gold-700 mb-4">
              Mein Atelier finden
            </h2>
            <p class="font-body text-gray-600 italic">
              Hier entsteht Ihre individuelle Blumenkreation
            </p>
          </div>
          
          {/* Map Placeholder */}
          <div class="bg-gold-50  border-2 border-dashed border-gold-300 p-12 text-center">
            <div class="mb-4">
              <svg class="w-16 h-16 mx-auto text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h3 class="font-heading text-2xl text-gold-700 mb-2">
              Workshop-Standort
            </h3>
            <p class="font-body text-gray-600 mb-4">
            Gerne stelle ich eine schöne Location für euren Workshop zur Verfügung oder wir finden gemeinsam einen Ort, an dem Ihr euch wohl fühlt.<br>Du möchtest den Workshop bei dir Zuhause machen? <br> Sehr gerne komme ich zu dir! <br>
            <br>
              
            </p>
            
            {/* Placeholder for actual map embed */}
            <div class="mt-6 p-4 bg-gold-100  inline-block">
              <p class="font-body text-gold-700 text-sm">
                📍 60km Umkreis Böbingen an der Rems
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Social Media Section */}
    <section class="py-16 bg-champagne-50">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="font-heading text-4xl text-gold-700 mb-4">
            Folgen Sie mir
          </h2>
          <p class="font-body text-gray-600 italic mb-8">
            Lassen Sie sich von meinen Kreationen inspirieren
          </p>
          
          {/* Social Links */}
          <div class="flex flex-wrap justify-center gap-6">
            {/* Instagram Placeholder */}
            <a 
              href={siteConfig.social.instagram} target="_blank" 
              class="flex items-center gap-3 px-6 py-4 bg-white hover: transition-all border border-gold-200/50 group"
            >
              <svg class="w-8 h-8 text-champagne-500 group-hover:text-champagne-600 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.226 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              <span class="font-body text-gray-700 group-hover:text-gold-700 transition-colors">
                Instagram
              </span>
            </a>
            
            {/* Pinterest Placeholder */}
            <a 
              href="#" 
              class="flex items-center gap-3 px-6 py-4 bg-white   hover: transition-all border border-gold-200/50 group"
            >
              <svg class="w-8 h-8 text-champagne-500 group-hover:text-champagne-600 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.623 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
              </svg>
              <span class="font-body text-gray-700 group-hover:text-gold-700 transition-colors">
                Pinterest
              </span>
            </a>
            
            {/* Facebook Placeholder */}
            <a 
              href="#" 
              class="flex items-center gap-3 px-6 py-4 bg-white   hover: transition-all border border-gold-200/50 group"
            >
              <svg class="w-8 h-8 text-champagne-500 group-hover:text-champagne-600 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.41c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              <span class="font-body text-gray-700 group-hover:text-gold-700 transition-colors">
                Facebook
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* CTA Section */}
    <section class="py-16 bg-gold-100">
      <div class="container mx-auto px-4 text-center">
        <h2 class="font-heading text-4xl text-gold-700 mb-4">
          Was wünschst Du dir?
        </h2>
        <p class="font-body text-gray-700 mb-8 max-w-2xl mx-auto">
          Ich stehe Ihnen gerne zur Verfügung. Kontaktieren Sie mich für individuelle Anfragen 
          oder um einen Termin zu vereinbaren.
        </p>
        <a
          href="/kontakt"
          class="inline-block px-8 py-4 bg-champagne-400 text-white  font-body text-lg
            hover:bg-champagne-500 transition-all duration-300  hover:"
        >
          Jetzt kontaktieren
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
