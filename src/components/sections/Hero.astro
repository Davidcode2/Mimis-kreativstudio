---
interface Props {
  title?: string;
  subtitle?: string;
  backgroundImage?: string;
  showCta?: boolean;
}

const {
  title = 'Mimis-Kreativstudio',
  subtitle = 'Handgefertigte Blumenkreationen für Ihre besonderen Momente',
  backgroundImage = '/images/hero/hero-default.webp',
  showCta = true
} = Astro.props;
---

<section class="relative h-screen min-h-[500px] md:min-h-[600px] flex items-center justify-center overflow-hidden">
  {/* Background Image */}
  <div class="absolute inset-0 z-0">
    <img
      src={backgroundImage}
      alt="Hero background"
      class="w-full h-full object-cover brightness-125"
    />
    <div class="absolute inset-0 bg-radial from-white/90 via-white/80 to-white/20"></div>
  </div>

  {/* Content */}
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-gold-700 mb-3 sm:mb-4 tracking-wide">
      {title}
    </h1>
    <p class="font-body text-lg sm:text-xl md:text-2xl text-gold-700 mb-6 sm:mb-8 font-light italic">
      {subtitle}
    </p>
    
    {showCta && (
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a
          href="/leistungen/"
          class="inline-block px-6 sm:px-8 py-2.5 sm:py-3 border border-champagne-400 text-gold-700
            hover:bg-champagne-100 hover:border-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
        >
          Meine Leistungen
        </a>
        <a
          href="/kontakt"
          class="inline-block px-6 sm:px-8 py-2.5 sm:py-3 bg-champagne-400 text-gold-800
            hover:bg-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
        >
          Hallo sagen
        </a>
      </div>
    )}
  </div>

  {/* Decorative flourish */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-8 h-8 text-gold-500" fill="currentColor" viewBox="0 0 24 24">
      <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
    </svg>
  </div>
</section>
