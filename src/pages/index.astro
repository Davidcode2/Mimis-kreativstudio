---
// Trigger build - 2026-03-15 - v4 (with src/ fix)
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ServicesList from '../components/sections/ServicesList.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import { pageMeta, heroContent, introContent } from '../data/page-content';

const { title, description } = pageMeta.home;
const hero = heroContent.home;
---

<BaseLayout title={title} description={description}>
  <main>
    <!-- Hero Section -->
    <Hero
      title={hero.title}
      subtitle={hero.subtitle}
      backgroundImage={hero.backgroundImage}
      showCta={hero.showCta}
    />

    <!-- Introduction -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 text-center max-w-3xl">
        <p class="font-body text-xl text-gray-700 leading-relaxed italic">
          {introContent.quote}
        </p>
        <div class="w-16 h-px bg-gold-400 mx-auto mt-6"></div>
      </div>
    </section>

    <!-- Services List -->
    <ServicesList />

    <!-- About Section -->
    <AboutSection />

    <!-- CTA Section -->
    <CTASection />
  </main>
</BaseLayout>
