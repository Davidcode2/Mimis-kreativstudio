---
import { ctaContent } from '../../data/page-content';
---

<section class="py-12 sm:py-16 md:py-20 bg-gradient-to-br from-champagne-50 to-champagne-100">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-gold-700 mb-4 sm:mb-6">
        {ctaContent.title}
      </h2>
      <p class="font-body text-lg sm:text-xl text-gray-700 mb-6 sm:mb-8 max-w-2xl mx-auto">
        {ctaContent.subtitle}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center px-4">
        <a
          href={ctaContent.primaryButton.href}
          class="inline-block px-6 sm:px-8 py-2.5 sm:py-3 bg-champagne-400 text-gold-800 hover:bg-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
        >
          {ctaContent.primaryButton.text}
        </a>
        <a
          href={ctaContent.secondaryButton.href}
          class="inline-block px-6 sm:px-8 py-2.5 sm:py-3 border border-champagne-400 text-gold-700 hover:bg-champagne-100 hover:border-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
        >
          {ctaContent.secondaryButton.text}
        </a>
      </div>

      {/* Contact info cards */}
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mt-10 sm:mt-12 px-2 sm:px-0">
        {ctaContent.contactCards.map((card, index) => (
          <a href={card.href} class="bg-white p-5 sm:p-6 hover:bg-gold-50 transition-colors">
            <div class={`w-10 sm:w-12 h-10 sm:h-12 flex items-center justify-center mx-auto mb-3 sm:mb-4 ${index === 1 ? 'bg-champagne-100' : 'bg-gold-100'}`}>
              {card.icon === 'instagram' && (
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gold-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.226 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              )}
              {card.icon === 'contact' && (
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-champagne-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              )}
              {card.icon === 'location' && (
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              )}
            </div>
            <h3 class="font-heading text-base sm:text-lg text-gold-700 mb-2">{card.title}</h3>
            <p class="text-gray-600 text-sm">{card.value}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
