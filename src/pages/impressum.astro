---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';
import { pageMeta, legalContent } from '../data/page-content';

const { title, description } = pageMeta.impressum;
const content = legalContent.impressum;
---

<BaseLayout title={title} description={description}>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="font-heading text-4xl md:text-5xl text-gold-700 mb-8">{content.title}</h1>
      
      <div class="prose prose-lg font-body text-gray-700">
        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">{content.sections.provider.title}</h2>
        <p>
          <strong>{siteConfig.businessName}</strong><br>
          {siteConfig.ownerName}<br>
          {siteConfig.address.street}<br>
          {siteConfig.address.zipCode} {siteConfig.address.city}
        </p>

        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">{content.sections.contact.title}</h2>
        <p>
          {siteConfig.phone ? `Telefon: ${siteConfig.phone}<br>` : ''}
          E-Mail: {siteConfig.email}
        </p>

        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">{content.sections.vat.title}</h2>
        <p>
          {content.sections.vat.text}<br>
          {siteConfig.vatId || '[USt-IdNr.]'}
        </p>

        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">{content.sections.content.title}</h2>
        <p>
          {siteConfig.ownerName}<br>
          {siteConfig.address.fullAddress}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>