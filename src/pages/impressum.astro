---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site-config';

const title = 'Impressum';
const description = 'Impressum und rechtliche Informationen für Mimis-kreativstudio.';
---

<BaseLayout title={title} description={description}>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="font-heading text-4xl md:text-5xl text-gold-700 mb-8">Impressum</h1>
      
      <div class="prose prose-lg font-body text-gray-700">
        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">Angaben gemäß § 5 TMG</h2>
        <p>
          <strong>{siteConfig.businessName}</strong><br>
          {siteConfig.ownerName}<br>
          {siteConfig.address.street}<br>
          {siteConfig.address.zipCode} {siteConfig.address.city}
        </p>

        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">Kontakt</h2>
        <p>
          {siteConfig.phone ? `Telefon: ${siteConfig.phone}<br>` : ''}
          E-Mail: {siteConfig.email}
        </p>

        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">Umsatzsteuer-ID</h2>
        <p>
          Umsatzsteuer-Identifikationsnummer gemäß §27 a Umsatzsteuergesetz:<br>
          {siteConfig.vatId || '[USt-IdNr.]'}
        </p>

        <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>
          {siteConfig.ownerName}<br>
          {siteConfig.address.fullAddress}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>