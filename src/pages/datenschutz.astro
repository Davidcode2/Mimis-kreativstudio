---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageMeta, legalContent } from '../data/page-content';

const { title, description } = pageMeta.datenschutz;
const content = legalContent.datenschutz;
---

<BaseLayout title={title} description={description}>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="font-heading text-4xl md:text-5xl text-gold-700 mb-8">{content.title}</h1>
      
      <div class="prose prose-lg font-body text-gray-700 space-y-6">
        {content.sections.map((section) => (
          <>
            <h2 class="font-heading text-2xl text-gold-600 mt-8 mb-4">{section.title}</h2>
            {section.subsections ? (
              section.subsections.map((subsection) => (
                <>
                  <h3 class="font-heading text-xl text-gold-600 mt-6 mb-3">{subsection.title}</h3>
                  <p>{subsection.text}</p>
                </>
              ))
            ) : (
              <p>{section.text}</p>
            )}
          </>
        ))}

        <p class="mt-8 text-sm text-gray-500">
          {content.footer}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>