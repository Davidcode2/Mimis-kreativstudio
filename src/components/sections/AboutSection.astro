---
interface Props {
  photoAlt?: string;
}

const {
  photoAlt = 'Miriam Mangold - Inhaberin von Mimis-kreativstudio'
} = Astro.props;
---

<section id="ueber-mich" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        {/* Photo */}
        <div class="relative order-2 md:order-1">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-xl bg-gray-100">
            <img
              src="/images/about/miriam-placeholder.jpg"
              alt={photoAlt}
              class="w-full h-full object-cover"
            />
          </div>
          {/* Decorative frame */}
          <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-gold-400 rounded-2xl -z-10"></div>
        </div>

        {/* Content */}
        <div class="order-1 md:order-2">
          <h2 class="font-heading text-4xl md:text-5xl text-gold-700 mb-6">
            Hallo, ich bin Miriam
          </h2>
          <div class="w-20 h-1 bg-rose-400 rounded-full mb-6"></div>
          
          <div class="space-y-6 font-body text-gray-700 leading-relaxed">
            <p>
              Willkommen bei <strong>Mimis-kreativstudio</strong> – meinem kleinen Reich der Blumen 
              und kreativen Gestaltung. Hier entstehen mit viel Liebe zum Detail handgefertigte 
              Blumenkreationen, die Ihre besonderen Momente unvergesslich machen.
            </p>
            <p>
              Als Floristik-Meisterin verbinde ich traditionelles Handwerk mit modernem 
              Design. Ob Hochzeit, Adventszeit oder ein ganz persönlicher Anlass – 
              ich gestalte individuelle Arrangements, die Ihre Vision Wirklichkeit werden lassen.
            </p>
            <p>
              In meinen Workshops teile ich meine Leidenschaft für die Kunst der Floristik 
              und möchte Ihnen beibringen, wie Sie selbst wunderschöne Blumenkreationen 
              gestalten können.
            </p>
          </div>

          {/* Highlights */}
          <div class="grid grid-cols-3 gap-4 mt-8">
            <div class="text-center p-4 bg-gold-50 rounded-lg">
              <span class="block font-heading text-3xl text-gold-600">10+</span>
              <span class="text-sm text-gray-600">Jahre Erfahrung</span>
            </div>
            <div class="text-center p-4 bg-rose-50 rounded-lg">
              <span class="block font-heading text-3xl text-rose-500">500+</span>
              <span class="text-sm text-gray-600"> zufriedene Kunden</span>
            </div>
            <div class="text-center p-4 bg-gold-50 rounded-lg">
              <span class="block font-heading text-3xl text-gold-600">6</span>
              <span class="text-sm text-gray-600">Kernleistungen</span>
            </div>
          </div>

          {/* CTA */}
          <div class="mt-8">
            <a
              href="/kontakt"
              class="inline-flex items-center px-6 py-3 bg-gold-500 text-white rounded-lg
                hover:bg-gold-600 transition-all duration-300 font-body"
            >
              Lernen Sie mich kennen
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>