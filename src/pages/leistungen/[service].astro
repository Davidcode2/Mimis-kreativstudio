---
import PageLayout from '../../layouts/PageLayout.astro';
import { services, getServiceBySlug } from '../../data/services';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<PageLayout
  title={service.title}
  description={service.shortDescription}
  heroImage={service.heroImage}
  heroTitle={service.title}
  heroSubtitle={service.subtitle}
>
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <!-- Service Description -->
      <div class="mb-16">
        <p class="text-xl leading-relaxed text-gray-700">
          {service.fullDescription}
        </p>
      </div>

      <!-- Size/Variant Options -->
      {service.sizes && service.sizes.length > 0 && (
        <div class="mb-16">
          <h2 class="font-heading text-3xl text-gray-900 mb-8 text-center">
            Größen & Varianten
          </h2>
          <div class="grid md:grid-cols-3 gap-6">
            {service.sizes.map((size) => (
              <div class="bg-gold-50 p-6 border border-gold-200">
                <h3 class="font-heading text-xl text-gold-700 mb-3">{size.name}</h3>
                <p class="text-gray-600">{size.description}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Image Gallery -->
      <div class="mb-16">
        <h2 class="font-heading text-3xl text-gray-900 mb-8 text-center">
          Galerie
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          {service.images.map((image) => (
            <div class="aspect-[4/3] overflow-hidden shadow-md">
              <img
                src={image.src}
                alt={image.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- CTA Section -->
      <div class="text-center">
        <a
          href={service.ctaLink}
          class="inline-block px-6 sm:px-8 py-2.5 sm:py-3 bg-champagne-400 text-gold-800 hover:bg-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
        >
          {service.ctaText}
        </a>
      </div>
    </div>
  </section>

  <!-- Back Link -->
  <section class="py-8 px-4 border-t border-gray-100">
    <div class="container mx-auto max-w-4xl">
      <a
        href="/leistungen"
        class="inline-flex items-center text-gold-600 hover:text-gold-700 font-medium"
      >
        ← Zurück zu allen Leistungen
      </a>
    </div>
  </section>
</PageLayout>