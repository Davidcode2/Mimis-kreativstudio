---
interface Props {
  photoAlt?: string;
}

const {
  photoAlt = 'Miriam Mangold - Inhaberin von Mimis-kreativstudio'
} = Astro.props;
---

<section id="ueber-mich" class="py-12 sm:py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
        {/* Photo */}
        <div class="relative order-2 md:order-1">
          <div class="aspect-[3/4] overflow-hidden bg-gray-100 border border-champagne-300">
            <img
              src="/images/workshop_collage_packaged.webp"
              alt={photoAlt}
              class="w-full h-full object-cover"
            />
          </div>
          {/* Decorative frame */}
          <div class="absolute -bottom-2 -right-2 sm:-bottom-4 sm:-right-4 w-full h-full border-2 border-champagne-400 -z-10"></div>
        </div>

        {/* Content */}
        <div class="order-1 md:order-2">
          <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-gold-700 mb-4 sm:mb-6">
            Hallo, ich bin Miriam
          </h2>
          <div class="w-16 sm:w-20 h-1 bg-champagne-400 mb-4 sm:mb-6"></div>
          
          <div class="space-y-4 sm:space-y-6 font-body text-gray-700 leading-relaxed text-sm sm:text-base">
            <p>
              Willkommen bei <strong>Mimis-kreativstudio</strong> – meinem kleinen Reich der Blumen 
              und kreativen Gestaltung. Hier entstehen mit viel Liebe zum Detail handgefertigte 
              Blumenkreationen, die Ihre besonderen Momente unvergesslich machen.
            </p>
            <p>
              Als Blumenkunst-Meisterin verbinde ich traditionelles Handwerk mit modernem 
              Design. Ob Hochzeit, Adventszeit oder ein ganz persönlicher Anlass – 
              ich gestalte individuelle Arrangements, die Ihre Vision Wirklichkeit werden lassen.
            </p>
            <p>
              In meinen Workshops teile ich meine Leidenschaft für die Kunst der Blumenbindekunst 
              und möchte Ihnen beibringen, wie Sie selbst wunderschöne Blumenkreationen 
              gestalten können.
            </p>
          </div>

          {/* Highlights */}
          <div class="grid grid-cols-3 gap-3 sm:gap-4 mt-6 sm:mt-8">
            <div class="text-center p-3 sm:p-4 bg-champagne-50 border border-champagne-300">
              <span class="block font-heading text-2xl sm:text-3xl text-gold-600">10+</span>
              <span class="text-xs sm:text-sm text-gray-600">Jahre Erfahrung</span>
            </div>
            <div class="text-center p-3 sm:p-4 bg-champagne-100 border border-champagne-300">
              <span class="block font-heading text-2xl sm:text-3xl text-champagne-600">500+</span>
              <span class="text-xs sm:text-sm text-gray-600"> zufriedene Kunden</span>
            </div>
            <div class="text-center p-3 sm:p-4 bg-champagne-50 border border-champagne-300">
              <span class="block font-heading text-2xl sm:text-3xl text-gold-600">6</span>
              <span class="text-xs sm:text-sm text-gray-600">Kernleistungen</span>
            </div>
          </div>

          {/* CTA */}
          <div class="mt-6 sm:mt-8">
            <a
              href="/kontakt"
              class="inline-flex items-center px-5 sm:px-6 py-2.5 sm:py-3 bg-champagne-400 text-gold-800 border border-champagne-500
                hover:bg-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
            >
              Lernen Sie mich kennen
              <svg class="w-4 h-4 sm:w-5 sm:h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
