---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import { pageMeta, heroContent } from '../data/page-content';

const { title, description } = pageMeta.leistungen;
const hero = heroContent.leistungen;
---

<BaseLayout title={title} description={description}>
  <Hero 
    title={hero.title}
    subtitle={hero.subtitle}
    backgroundImage={hero.backgroundImage}
    showCta={hero.showCta}
  />
  <ServicesGrid />
</BaseLayout>
