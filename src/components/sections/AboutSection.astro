---
import { aboutContent } from '../../data/page-content';

interface Props {
  photoAlt?: string;
}

const {
  photoAlt = aboutContent.photoAlt
} = Astro.props;
---

<section id="ueber-mich" class="py-12 sm:py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
        {/* Photo */}
        <div class="relative order-2 md:order-1">
          <div class="aspect-[3/4] overflow-hidden bg-gray-100 border border-champagne-300">
            <img
              src={aboutContent.photoSrc}
              alt={photoAlt}
              class="w-full h-full object-cover"
            />
          </div>
          {/* Decorative frame */}
          <div class="absolute -bottom-2 -right-2 sm:-bottom-4 sm:-right-4 w-full h-full border-2 border-champagne-400 -z-10"></div>
        </div>

        {/* Content */}
        <div class="order-1 md:order-2">
          <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl text-gold-700 mb-4 sm:mb-6">
            {aboutContent.title}
          </h2>
          <div class="w-16 sm:w-20 h-1 bg-champagne-400 mb-4 sm:mb-6"></div>
          
          <div class="space-y-4 sm:space-y-6 font-body text-gray-700 leading-relaxed text-sm sm:text-base">
            {aboutContent.paragraphs.map((paragraph) => (
              <p set:html={paragraph} />
            ))}
          </div>

          {/* Highlights */}
          <div class="grid grid-cols-3 gap-3 sm:gap-4 mt-6 sm:mt-8">
            {aboutContent.highlights.map((highlight, index) => (
              <div class={`text-center p-3 sm:p-4 border border-champagne-300 ${index === 1 ? 'bg-champagne-100' : 'bg-champagne-50'}`}>
                <span class={`block font-heading text-2xl sm:text-3xl ${index === 1 ? 'text-champagne-600' : 'text-gold-600'}`}>{highlight.value}</span>
                <span class="text-xs sm:text-sm text-gray-600">{highlight.label}</span>
              </div>
            ))}
          </div>

          {/* CTA */}
          <div class="mt-6 sm:mt-8">
            <a
              href="/kontakt"
              class="inline-flex items-center px-6 sm:px-8 py-2.5 sm:py-3 bg-champagne-400 text-gold-800
                hover:bg-champagne-500 transition-all duration-300 font-body text-sm sm:text-base"
            >
              {aboutContent.ctaText}
              <svg class="w-4 h-4 sm:w-5 sm:h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
